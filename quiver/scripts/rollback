#!/bin/bash
# shellcheck disable=SC2002,SC2162,SC2086
echo -e "
-------------------------------------------------------------------------
$(tput setaf 4)
             █████╗ ██████╗  ██████╗██╗  ██╗███████╗██████╗
            ██╔══██╗██╔══██╗██╔════╝██║  ██║██╔════╝██╔══██╗
            ███████║██████╔╝██║     ███████║█████╗  ██████╔╝
            ██╔══██║██╔══██╗██║     ██╔══██║██╔══╝  ██╔══██╗
            ██║  ██║██║  ██║╚██████╗██║  ██║███████╗██║  ██║
            ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝
$(tput sgr0)
-------------------------------------------------------------------------
                        Snapshot rollback script
-------------------------------------------------------------------------"

root_uuid=$(lsblk -o UUID,LABEL | grep "$(< /etc/hostname)" | awk '{print $1}')
snapshot_path=$(awk -F'subvol=' '{print $2}' /proc/cmdline | awk '{print $1}')

if [ $snapshot_path = "@" ]; then
    echo "This script only works when you are booted in to a snapshot"
    read -p "Press any key to exit..."
    exit
fi

sudo echo -e "Mounting root on /mnt" || exit
sudo mount -t btrfs "/dev/disk/by-uuid/$root_uuid" /mnt

echo -e "Moving previous root"
sudo mv /mnt/@ /mnt/@prev-root

echo -e "Setting current snapshot as new root"
sudo btrfs subvolume snapshot /$snapshot_path /mnt/@

if [ -e "/mnt/@/var/lib/pacman/db.lck" ]; then
	echo -e "Removing pacman db.lck"
	sudo rm /mnt/@/var/lib/pacman/db.lck
fi

echo -e "Removing previous root"
sudo btrfs subvolume delete /mnt/@prev-root/var/lib/portables
sudo btrfs subvolume delete /mnt/@prev-root/var/lib/machines
sudo btrfs subvolume delete /mnt/@prev-root
sudo rm -rf /mnt/@prev-root

echo -e "Unmounting /mnt"
sudo umount -R /mnt

read -p "Press any key to reboot..."
reboot